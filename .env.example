# ============================================================
# PUNTA — Configuración de entorno
# ============================================================
# Plantilla para nuevas instalaciones. Para usarla:
#   copy .env.example .env
#   php artisan key:generate
#   Editar DB_DATABASE, DB_USERNAME, DB_PASSWORD según tu máquina.
#
# El .env NUNCA se sube a Git (contiene claves y contraseñas).
# El .env.example SÍ se sube (es documentación).
# ============================================================

APP_NAME=PUNTA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos ───────────────────────────────────────────
# Laragon: root sin contraseña, puerto 3306.
# Servidor: cambiar host, usuario y contraseña.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=punta
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Cola de trabajos ────────────────────────────────────────
# "sync" = los Jobs se ejecutan inmediatamente (desarrollo local).
#          Esto es OBLIGATORIO para que la conversión Word→Markdown
#          funcione sin necesidad de correr "php artisan queue:work".
# "database" o "redis" = los Jobs se encolan (producción con worker).
#          Requiere correr: php artisan queue:work
QUEUE_CONNECTION=sync

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Correo ──────────────────────────────────────────────────
# "log" = correos se escriben en storage/logs/ (desarrollo).
# "smtp" = envío real (producción).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@lapaz.gob.mx"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── LibreOffice (opcional) ──────────────────────────────────
# Convierte Word a PDF con fidelidad completa (tablas, imágenes,
# formato). Si está vacío, PUNTA intenta autodetectar la ruta.
# Si LibreOffice no está instalado, usa Dompdf como fallback.
#
# Windows: "C:\Program Files\LibreOffice\program\soffice.exe"
# Linux:   /usr/bin/soffice
# Docker:  /usr/bin/soffice
# Vacío:   autodetección
LIBREOFFICE_PATH=
