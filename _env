# ══════════════════════════════════════════════════════════════════════
#  ASISTENTE DEL BUSCADOR (DeepSeek)
# ══════════════════════════════════════════════════════════════════════
#
# Redacta una respuesta en lenguaje natural a partir de los resultados que el
# buscador YA encontró. No busca ni inventa: solo redacta lo que se le da.
#
# ── EL INTERRUPTOR ──
#
# Con ASISTENTE_ACTIVO=false, el asistente NO HACE NINGUNA LLAMADA: sale antes
# de tocar la red, y el buscador funciona exactamente como siempre.
#
# Es lo primero que hay que apagar si algo va mal en producción: si la API se
# vuelve loca, si la factura se dispara, o si alguien encuentra una respuesta
# mala. Sin despliegue, sin migración, sin tocar código.
#
# NO LO ENCIENDAS hasta que la vista del buscador distinga visualmente una
# respuesta GENERADA por la IA de una definición legal curada por una persona.
# Un ciudadano tiene derecho a saber si lo que lee lo escribió el Ayuntamiento
# o lo redactó una máquina.
ASISTENTE_ACTIVO=false

# La clave de platform.deepseek.com → API keys.
#
# Empieza por sk- y SOLO SE VE UNA VEZ al crearla.
#
# NUNCA la pongas en el código ni la subas a git. Este archivo está en el
# .gitignore por ese motivo. Si una key acaba en un commit público, DeepSeek la
# desactiva sola en cuanto la detecta — pero para entonces alguien pudo haberla
# usado a tu costa.
DEEPSEEK_API_KEY=

DEEPSEEK_URL=https://api.deepseek.com/chat/completions

# ⚠️ OJO CON ESTE NOMBRE ⚠️
#
# NO uses 'deepseek-chat'. Ese nombre —y 'deepseek-reasoner'— quedan RETIRADOS
# E INACCESIBLES el 24 de julio de 2026 a las 15:59 UTC. Después de esa fecha,
# cualquier petición que los use falla. Es un corte duro, sin prórroga.
#
# 'deepseek-v4-flash' es barato, rápido, y de sobra para lo que hace este
# asistente: leer cuatro artículos y resumirlos en tres frases.
DEEPSEEK_MODELO=deepseek-v4-flash

# Ocho segundos y ni uno más. Un buscador municipal no puede quedarse colgado
# esperando a una API externa: si tarda, se devuelve la lista de resultados de
# siempre y a otra cosa.
ASISTENTE_TIMEOUT=8

# Cuánto se guarda cada respuesta. Cien ciudadanos preguntando lo mismo no
# pueden costar cien llamadas a una API que se paga por uso.
ASISTENTE_CACHE_HORAS=24
