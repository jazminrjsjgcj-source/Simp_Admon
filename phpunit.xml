<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!--
            La Agenda se exporta rellenando las plantillas oficiales de la ATDT, que
            son libros de 8 hojas y ~32 000 celdas. Abrir uno cuesta decenas de MB en
            PhpSpreadsheet, y estas pruebas abren el archivo generado para leer sus
            celdas: durante un instante hay dos libros vivos. Con los 128 MB por
            defecto de la imagen no cabe, y el fallo se manifiesta como un fatal sin
            traza ("Premature end of PHP process"), que despista mucho.

            Va aquí y no en la línea de comandos porque `artisan test` lanza PHPUnit
            en un proceso hijo que NO hereda los -d del proceso padre: pasar
            `php -d memory_limit=512M artisan test` no surte ningún efecto.
        -->
        <ini name="memory_limit" value="512M"/>

        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>

        <!--
            Las pruebas corren contra PostgreSQL, no contra SQLite.

            Es a propósito: el sistema se despliega en PostgreSQL y los motores no
            se comportan igual (ILIKE, la búsqueda de texto completo, los tipos de
            columna, la estrictez con las columnas inexistentes...). Una prueba que
            pasara en SQLite podría fallar igualmente en producción, así que no
            serviría de mucho.

            Se usa una base APARTE (punta_testing) para no tocar los datos de
            desarrollo. Hay que crearla una vez:

              docker compose exec db createdb -U postgres punta_testing
        -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="db"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="punta_testing"/>
        <env name="DB_USERNAME" value="postgres"/>
        <env name="DB_PASSWORD" value="punta123"/>
        <env name="DB_URL" value=""/>

        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
